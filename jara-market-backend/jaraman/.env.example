# =============================================================================
# JaraMarket — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

APP_NAME="JaraMarket"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Lagos

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DATABASE
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jaramarket
DB_USERNAME=root
DB_PASSWORD=

# CORS - Allowed Origins (Production website URL)
ALLOWED_ORIGINS=https://jaramarket-web-application-production.up.railway.app

# =============================================================================
# CACHE & SESSION
# =============================================================================
CACHE_STORE=database
CACHE_PREFIX=jaramarket_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# QUEUE (set to database for production; sync for local/testing)
# =============================================================================
QUEUE_CONNECTION=database

# =============================================================================
# MAIL — High Performance Resend Transactional Mailer
# =============================================================================
MAIL_MAILER=resend
RESEND_API_KEY=your-resend-api-key-here
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FROM_ADDRESS="info@jaramarket.com"

# =============================================================================
# FILESYSTEM / STORAGE
# =============================================================================
FILESYSTEM_DISK=local

# For production (AWS S3):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# FIREBASE — Push Notifications (replaces Kafka)
# =============================================================================
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download JSON
# 3. Save it to: storage/app/firebase/service-account.json
# 4. Fill in values below

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json

# =============================================================================
# PAYSTACK — Payment Gateway
# =============================================================================
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

PAYMENT_GATEWAY=paystack

# =============================================================================
# FLUTTERWAVE (optional, secondary gateway)
# =============================================================================
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# =============================================================================
# TERMII — SMS Gateway (for OTP)
# =============================================================================
TERMII_API_KEY=
TERMII_SENDER_ID=JaraMarket

# =============================================================================
# SANCTUM — API Authentication
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# =============================================================================
# BROADCASTING (optional — for real-time features)
# =============================================================================
BROADCAST_CONNECTION=log

# Pusher / Reverb (if using WebSockets):
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http

# =============================================================================
# REDIS (optional — for queue/cache in production)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# KAFKA (legacy — now replaced by Firebase. Keep for reference only)
# =============================================================================
# KAFKA_BROKERS=kafka:9092
# KAFKA_CONSUMER_GROUP_ID=jaramarket-consumer-group
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Paystack webhook secret (set to your Paystack webhook secret key)
PAYSTACK_WEBHOOK_SECRET=

# Termii config
TERMII_BASE_URL=https://api.ng.termii.com

# App referral bonus %
APP_REFERRAL_BONUS=10

# =============================================================================
# VITE / FRONTEND ASSETS (if using Vite)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# SOCIALITE - OAUTH PROVIDERS
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://jara-market-laravel-backend-production.up.railway.app/api/jaram/social/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=
